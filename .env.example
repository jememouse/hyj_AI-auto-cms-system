# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Feishu/Lark Configuration
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Optional: OpenAI Configuration (if used as fallback)
OPENAI_API_KEY=sk-Start...

# Image API Keys (Pollinations, Pexels, Pixabay)
POLLINATIONS_API_KEYS=sk_key1,sk_key2,sk_key3
PEXELS_API_KEY=your_pexels_api_key
PIXABAY_API_KEY=your_pixabay_api_key

# Deployment Configuration
# Set to 'true' to run the task immediately when the container starts
RUN_ON_STARTUP=true

# Google GenAI Configuration (Primary)
GOOGLE_GENAI_API_KEY=your_google_ai_studio_api_key_here

# Feishu Additional Config
FEISHU_BASE_ID=your_feishu_base_id_here
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here

# Google Sheets Config
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_BACKUP_ID=your_backup_sheet_id_here

# WellCMS Configuration
WELLCMS_USERNAME=product_manager
WELLCMS_PASSWORD=your_wellcms_password_here
WELLCMS_LOGIN_URL=https://your_domain.com/news/user-login.html
WELLCMS_ADMIN_URL=https://your_domain.com/news/admin/index.php
WELLCMS_POST_URL=https://your_domain.com/news/admin/index.php?0=content&1=create&fid=0

# Cloudflare D1 Database Config
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_D1_DATABASE_ID=your_d1_database_id_here
CF_API_TOKEN=your_cloudflare_api_token_here
